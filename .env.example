# OINIO Soul System - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# ==============================================
# WALLET CONFIGURATION (SOVEREIGN ONLY)
# ==============================================
# Local operator wallet - holds gas funds only
OPERATOR_WALLET_ADDRESS=0xYourOperatorWalletAddressHere

# Treasury contract address - holds all system funds
TREASURY_CONTRACT_ADDRESS=0xYourTreasuryContractAddressHere

# ==============================================
# NETWORK RPC ENDPOINTS
# ==============================================
POLYGON_RPC=https://polygon-rpc.com
OG_RPC=https://rpc.0g.ai

# ==============================================
# NODE CONFIGURATION
# ==============================================
NODE_ID=guardian-001
LOG_LEVEL=info
AUTO_EARNING_ENABLED=true

# ==============================================
# THRESHOLDS
# ==============================================
CRITICAL_GAS_THRESHOLD=0.05
OPERATIONAL_BUFFER=0.2