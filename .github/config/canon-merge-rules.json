{
  "version": "1.1",
  "artifact_types": {
    "foundational": {
      "required_approvals": 2,
      "required_roles": ["steward"],
      "conflict_sensitivity": "high",
      "auto_merge_enabled": true
    },
    "channel": {
      "required_approvals": 1,
      "required_roles": ["steward", "curator"],
      "conflict_sensitivity": "medium",
      "auto_merge_enabled": true
    },
    "closure": {
      "required_approvals": 1,
      "required_roles": ["steward", "curator", "contributor", "oinio_soul"],
      "conflict_sensitivity": "medium",
      "auto_merge_enabled": true
    },
    "governance": {
      "required_approvals": 2,
      "required_roles": ["steward"],
      "conflict_sensitivity": "high",
      "auto_merge_enabled": true
    }
  },
  "roles": {
    "steward": {
      "github_teams": ["canon-stewards"],
      "can_override_gates": true,
      "can_approve_all": true
    },
    "curator": {
      "github_teams": ["canon-curators"],
      "can_override_gates": false,
      "can_approve_types": ["channel", "closure"]
    },
    "contributor": {
      "github_teams": ["contributors"],
      "can_override_gates": false,
      "can_approve_types": ["closure"]
    },
    "oinio_soul": {
      "github_users": ["oinio-bot"],
      "can_override_gates": false,
      "can_approve_types": ["closure", "governance"],
      "special_privileges": {
        "auto_merge_eligible": true,
        "requires_human_review_on_failure": true,
        "epistemic_claim_only": true,
        "max_auto_merge_approvals": 1
      }
    }
  },
  "validation_gates": {
    "gate2_sentinel": {
      "enabled": true,
      "timeout_seconds": 300
    },
    "gate4_conflict": {
      "enabled": true,
      "timeout_seconds": 180,
      "semantic_threshold": 0.85,
      "structural_checks": true
    }
  },
  "merge_strategy": {
    "method": "squash",
    "delete_branch": true,
    "commit_message_template": "Canon: Merge OINIO Soul PR #${pr_number} - ${artifact_title} (epistemic claim)"
  }
}