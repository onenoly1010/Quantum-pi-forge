{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/quantum-pi/forge/canon-state-object-v1.1.schema.json",
  "title": "Canon State Object",
  "description": "Standardized output of the Canon State Machine. Execution ≠ Observation ≠ Claim. No layer may collapse into another. The final claim is never authoritative truth.",
  "type": "object",
  "required": [
    "canon_version",
    "canon_hash",
    "execution",
    "observation",
    "claim",
    "_meta"
  ],
  "additionalProperties": false,
  "properties": {
    "canon_version": {
      "type": "string",
      "description": "Version of the Canon State Machine specification.",
      "const": "1.1.0"
    },
    "canon_hash": {
      "type": "string",
      "description": "Deterministic SHA-256 hash of the canon directory contents after execution. Format: 'sha256:<hex>'."
    },
    "epistemic_status": {
      "type": "string",
      "enum": ["claim_only", "partial_claim", "unobserved_claim"],
      "description": "High-level summary: always indicates this is a claim, never 'verified' or 'true'."
    },
    "execution": {
      "type": "object",
      "required": ["state", "timestamp", "job_id"],
      "additionalProperties": false,
      "properties": {
        "state": {
          "type": "string",
          "enum": ["EXECUTION_PENDING", "EXECUTION_RUNNING", "EXECUTION_COMPLETED", "EXECUTION_FAILED", "EXECUTION_ABORTED", "EXECUTION_TIMED_OUT"],
          "description": "Raw runtime outcome. Exit code 0 does NOT imply correctness."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when execution completed/aborted (UTC)."
        },
        "job_id": {
          "type": "string",
          "description": "GitHub Actions job ID or run identifier."
        },
        "run_id": {
          "type": "string",
          "description": "GitHub workflow run ID (github.run_id)."
        },
        "run_attempt": {
          "type": "integer",
          "description": "GitHub run attempt number for retries."
        },
        "exit_code": {
          "type": ["integer", "null"],
          "description": "Process exit code (null if not applicable, e.g., aborted)."
        },
        "duration_ms": {
          "type": ["integer", "null"],
          "description": "Wall-clock duration in milliseconds."
        },
        "repository": {
          "type": "string",
          "description": "Repository full name (owner/repo)."
        },
        "ref": {
          "type": "string",
          "description": "Git ref (branch/tag) at execution time."
        }
      }
    },
    "observation": {
      "type": "object",
      "required": ["state", "timestamp"],
      "additionalProperties": false,
      "properties": {
        "state": {
          "type": "string",
          "enum": ["OBSERVATION_PENDING", "OBSERVATION_RUNNING", "OBSERVATION_VERIFIED", "OBSERVATION_PARTIAL", "OBSERVATION_FAILED", "OBSERVATION_MANUAL"],
          "description": "Neutral measurement of execution artifacts. Reads only; never modifies."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of observation completion (UTC)."
        },
        "verifier_hash": {
          "type": "string",
          "description": "SHA-256 hash of the verification script. Format: 'sha256:<hex>'."
        },
        "verifier_version": {
          "type": "string",
          "description": "Version or commit SHA of the verifier tool."
        },
        "invariants_checked": {
          "type": "integer",
          "minimum": 0
        },
        "invariants_passed": {
          "type": "integer",
          "minimum": 0
        },
        "invariants_failed": {
          "type": "integer",
          "minimum": 0
        },
        "integrity": {
          "type": "string",
          "enum": ["full", "partial", "unobserved", "failed", "human_attested"],
          "description": "Summary of observation quality. 'full' does NOT imply truth."
        },
        "details": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional detailed invariant results."
        }
      }
    },
    "claim": {
      "type": "object",
      "required": ["state", "timestamp", "claim_text"],
      "additionalProperties": false,
      "properties": {
        "state": {
          "type": "string",
          "const": "CLAIM_GENERATED",
          "description": "Always terminal. Never implies verification or truth."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the claim object was written (UTC)."
        },
        "claim_text": {
          "type": "string",
          "description": "Human-readable assertion. Must explicitly disclaim authority."
        },
        "authoritative": {
          "type": "boolean",
          "const": false
        },
        "verification_required": {
          "type": "boolean",
          "const": true
        },
        "integrity": {
          "type": "string",
          "enum": ["full", "partial", "unobserved", "execution_failed", "aborted", "timeout", "human_attested"],
          "description": "Propagated from observation or adjusted for execution failures."
        },
        "previous_claim_ref": {
          "type": ["string", "null"],
          "description": "Hash or run_id of the prior claim (for retry chains)."
        }
      }
    },
    "integrity_summary": {
      "type": "string",
      "description": "Quick human/machine-readable summary."
    },
    "_meta": {
      "type": "object",
      "required": ["schema_version", "generated_by"],
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.1.0"
        },
        "generated_by": {
          "type": "string",
          "description": "Workflow/file that produced this object."
        },
        "external_attestation_hook": {
          "type": ["object", "null"],
          "description": "Placeholder for external validation. Null by default.",
          "properties": {
            "attestor": { "type": "string" },
            "attestation_type": { "type": "string" },
            "reference": { "type": "string" },
            "timestamp": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": true
        },
        "extensions": {
          "type": "object",
          "description": "Open field for future Canon extensions without schema breakage.",
          "additionalProperties": true
        }
      }
    }
  }
}